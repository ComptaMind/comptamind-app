# Variables d'environnement ComptaMind
# Copier ce fichier en .env et remplir les valeurs pour le dev local
# Ces variables doivent aussi être configurées dans Netlify → Site settings → Environment variables

# Mot de passe d'accès au cabinet (v1 simple)
VITE_APP_PASSWORD=VotreMotDePasseIci

# Nom du cabinet affiché dans l'app
VITE_CABINET_NAME=Cabinet Kamgang

# Airtable — Personal Access Token (scope limité à la base appc6LMeUQJiX8gjG)
VITE_AIRTABLE_TOKEN=patXXXXXXXXXXXXXX
VITE_AIRTABLE_BASE_ID=appc6LMeUQJiX8gjG

# Secret webhook VPS (optionnel — laisser vide si non configuré côté VPS)
# Utilisé côté Netlify Functions uniquement (non exposé au navigateur)
WEBHOOK_SECRET=
